# ============================================
# Klipto Configuration
# ============================================
# Copy this file to .env and fill in your values

PROJECT_NAME="Klipto"

# ============================================
# Redis & Celery
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM Configuration
# ============================================
# Choose your LLM provider: openrouter, openai, anthropic, google
LLM_PROVIDER=openrouter

# Model to use (examples for each provider):
# - openrouter: deepseek/deepseek-chat, anthropic/claude-3.5-sonnet, openai/gpt-4o
# - openai: gpt-4o, gpt-4o-mini, gpt-4-turbo
# - anthropic: claude-3-5-sonnet-20241022
# - google: gemini-2.0-flash-exp
LLM_MODEL=deepseek/deepseek-chat

# ============================================
# API Keys (add the ones you need)
# ============================================
# OpenRouter - Recommended! Access to 100+ models
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenAI Direct - For direct GPT access
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key

# Anthropic Direct - For direct Claude access
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key

# Google AI - For direct Gemini access
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-google-key

# ============================================
# Whisper Configuration (Local Transcription)
# ============================================
# Model size: tiny, base, small, medium, large-v3
# Larger = more accurate but slower and needs more VRAM
WHISPER_MODEL=base

# Device: auto, cpu, cuda
WHISPER_DEVICE=auto

# Set to false to disable local Whisper (future cloud API support)
USE_LOCAL_WHISPER=true

# ============================================
# Video Processing
# ============================================
# Number of clips to generate by default
DEFAULT_NUM_CLIPS=3

# Clip duration limits (in seconds)
MIN_CLIP_DURATION=15.0
MAX_CLIP_DURATION=60.0

# Output video settings
OUTPUT_RESOLUTION=720x1280
OUTPUT_BITRATE=2M
OUTPUT_CODEC=libx264

# ============================================
# YOLO Configuration
# ============================================
# Model: yolov8n.pt (nano), yolov8s.pt (small), yolov8m.pt (medium)
# Or YOLO11: yolo11n.pt, yolo11s.pt
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5

# ============================================
# Scene Detection
# ============================================
# Lower = more sensitive (detects more scene changes)
SCENE_THRESHOLD=30.0

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Max upload size in bytes (default: 500MB)
MAX_UPLOAD_SIZE=524288000
